# 复制到 nginx conf.d 或站点配置后，按需改 server_name 与 root。
# 前端构建：cd /www/wwwroot/numflow/frontend && npm run build
# root 指向 Vite 的 dist 目录。

server {
    listen 80;
    server_name _;  # 改为你的域名，或暂用 _ 表示任意 Host（仅内网/测试时注意风险）

    root /www/wwwroot/numflow/frontend/dist;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
