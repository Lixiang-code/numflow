# ============================================================
# Numflow 后端环境变量配置模板
# 复制本文件为 .env，按实际填写后重启服务即可
# ============================================================

# ── 通义千问 / DashScope（必填，用于 Qwen 系列模型） ──────────
DASHSCOPE_API_KEY=
# 可选覆盖默认端点：
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen3.6-plus

# ── DeepSeek（选填，支持 deepseek-v4-flash / deepseek-v4-pro） ─
DEEPSEEK_API_KEY=
# 可选覆盖默认端点（默认 https://api.deepseek.com）：
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Mimo（选填，支持 mimo-v2-flash / mimo-v2-pro / mimo-v2.5 等）
MIMO_API_KEY=
# 可选覆盖默认端点（默认 https://token-plan-sgp.xiaomimimo.com/v1）：
# MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# ── 数据目录（选填，默认 <项目根>/data） ─────────────────────────
# NUMFLOW_DATA_DIR=/www/wwwroot/numflow/data

# ── 前端 CORS 允许来源（生产环境必填，逗号分隔） ─────────────────
# NUMFLOW_FRONTEND_ORIGINS=http://your-domain.com,https://your-domain.com

# ── 邀请码（选填，默认值见 config.py） ───────────────────────────
# NUMFLOW_INVITE_CODE=your_invite_code

# ── Session 有效天数（选填，默认 14） ────────────────────────────
# NUMFLOW_SESSION_DAYS=14
